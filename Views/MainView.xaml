<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MansuetoKarms.ViewModels"
             xmlns:m="clr-namespace:MansuetoKarms.Models"
             x:Class="MansuetoKarms.Views.MainView"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#EAF2FB"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Padding="24,20"
          RowSpacing="16">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackLayout Grid.Column="0" Spacing="4">
                <Label Text="Vehicles"
                       FontSize="28"
                       FontFamily="PoppinsBold"
                       TextColor="#0A1931" />
                <Label Text="Fleet Management"
                       FontSize="13"
                       TextColor="#5B7AA5" />
            </StackLayout>

            <Button Grid.Column="1"
                    Text="+ Add"
                    Command="{Binding NavigateToCreateCommand}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    CornerRadius="12"
                    Padding="24,12"
                    FontFamily="PoppinsSemiBold"
                    FontSize="14"
                    HeightRequest="46"
                    VerticalOptions="Center" />
        </Grid>

        <!-- ARCHIVE AND DELETE NAVIGATION BUTTONS -->
        <Grid Grid.Row="1" ColumnDefinitions="*,12,*" ColumnSpacing="12">

            <!-- ARCHIVE BUTTON -->
            <Border Grid.Column="0"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#B0CBE8"
                    StrokeThickness="1"
                    BackgroundColor="White">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToArchiveCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="14,12">
                    <Label Grid.Column="0"
                           Text="📦"
                           FontSize="20"
                           VerticalOptions="Center" />
                    <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Archive"
                               FontSize="14"
                               FontFamily="PoppinsSemiBold"
                               TextColor="#0A1931" />
                        <Label Text="Archived vehicles"
                               FontSize="11"
                               TextColor="#5B7AA5" />
                    </StackLayout>
                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="22"
                           TextColor="#5B7AA5"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- DELETE BUTTON -->
            <Border Grid.Column="2"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#FFCDD2"
                    StrokeThickness="1"
                    BackgroundColor="White">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToDeleteCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="14,12">
                    <Label Grid.Column="0"
                           Text="🗑️"
                           FontSize="20"
                           VerticalOptions="Center" />
                    <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Deleted"
                               FontSize="14"
                               FontFamily="PoppinsSemiBold"
                               TextColor="#0A1931" />
                        <Label Text="Deleted vehicles"
                               FontSize="11"
                               TextColor="#5B7AA5" />
                    </StackLayout>
                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="22"
                           TextColor="#5B7AA5"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

        </Grid>

        <!-- LOADING -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#1565C0"
                           HeightRequest="32" />

        <!-- VEHICLE LIST -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Vehicles}">

            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10"
                             Padding="24">
                    <Label Text="No vehicles"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#0A1931"
                           HorizontalOptions="Center" />
                    <Label Text="Tap + Add to get started"
                           FontSize="13"
                           TextColor="#5B7AA5"
                           HorizontalOptions="Center" />
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Vehicle">
                    <Border Margin="0,6"
                            Padding="18"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#B0CBE8"
                            StrokeThickness="1"
                            BackgroundColor="White">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="10">

                            <!-- ROW 0 — Name + Type -->
                            <HorizontalStackLayout Grid.Row="0" Spacing="10">
                                <Label Text="{Binding DisplayName}"
                                       FontSize="17"
                                       FontFamily="PoppinsSemiBold"
                                       TextColor="#0A1931"
                                       VerticalOptions="Center" />
                                <Border Padding="8,3"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        BackgroundColor="#D6EAF8">
                                    <Label Text="{Binding Type}"
                                           FontSize="11"
                                           TextColor="#1565C0" />
                                </Border>
                            </HorizontalStackLayout>

                            <!-- ROW 1 — Plate / Color / Seats -->
                            <HorizontalStackLayout Grid.Row="1" Spacing="16">
                                <Label Text="{Binding PlateNumber}"
                                       FontSize="13"
                                       FontFamily="PoppinsMedium"
                                       TextColor="#0A1931" />
                                <Label Text="{Binding Color}"
                                       FontSize="13"
                                       TextColor="#5B7AA5" />
                                <Label Text="{Binding Seats, StringFormat='{0} seats'}"
                                       FontSize="13"
                                       TextColor="#5B7AA5" />
                            </HorizontalStackLayout>

                            <!-- ROW 2 — Description -->
                            <Label Grid.Row="2"
                                   Text="{Binding Description}"
                                   FontSize="12"
                                   TextColor="#7BA0C7"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />

                            <!-- ROW 3 — Price + Status -->
                            <HorizontalStackLayout Grid.Row="3" Spacing="12">
                                <Label Text="{Binding PricePerDay, StringFormat='P{0:N0}/day'}"
                                       FontSize="18"
                                       FontFamily="PoppinsSemiBold"
                                       TextColor="#0A1931"
                                       VerticalOptions="Center" />
                                <Border Padding="10,4"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="Transparent"
                                        BackgroundColor="{Binding StatusBg}">
                                    <Label Text="{Binding Status}"
                                           FontSize="12"
                                           FontFamily="PoppinsSemiBold"
                                           TextColor="{Binding StatusColor}" />
                                </Border>
                            </HorizontalStackLayout>

                            <!-- ROW 4 — Action Buttons -->
                            <FlexLayout Grid.Row="4"
                                        Wrap="Wrap"
                                        JustifyContent="End"
                                        AlignItems="Center"
                                        Margin="0,6,0,0">

                                <Button Text="Edit"
                                        FontSize="12"
                                        BackgroundColor="#1565C0"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="18,9"
                                        Margin="4,4"
                                        MinimumWidthRequest="70"
                                        HeightRequest="38"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToUpdateCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Archive"
                                        FontSize="12"
                                        BackgroundColor="#87CEEB"
                                        TextColor="#0A1931"
                                        CornerRadius="8"
                                        Padding="18,9"
                                        Margin="4,4"
                                        MinimumWidthRequest="80"
                                        HeightRequest="38"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SoftDeleteCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Delete"
                                        FontSize="12"
                                        BackgroundColor="#FF3B30"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="18,9"
                                        Margin="4,4"
                                        MinimumWidthRequest="70"
                                        HeightRequest="38"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.HardDeleteCommand}"
                                        CommandParameter="{Binding .}" />
                            </FlexLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
