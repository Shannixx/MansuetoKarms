<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MansuetoKarms.ViewModels"
             xmlns:m="clr-namespace:MansuetoKarms.Models"
             x:Class="MansuetoKarms.Views.MainView"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#F5F5F7"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Padding="20,16"
          RowSpacing="14">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackLayout Grid.Column="0" Spacing="4">
                <Label Text="Vehicles"
                       FontSize="28"
                       FontFamily="PoppinsBold"
                       TextColor="#1A1A2E" />
                <Label Text="Fleet Management"
                       FontSize="13"
                       TextColor="#8E8E93" />
            </StackLayout>

            <Button Grid.Column="1"
                    Text="+ Add"
                    Command="{Binding NavigateToCreateCommand}"
                    BackgroundColor="#1A1A2E"
                    TextColor="White"
                    CornerRadius="12"
                    Padding="20,10"
                    FontFamily="PoppinsSemiBold"
                    FontSize="14"
                    VerticalOptions="Center" />
        </Grid>

        <!-- ARCHIVE TOGGLE -->
        <Border Grid.Row="1"
                Padding="16,12"
                StrokeShape="RoundRectangle 12"
                Stroke="#E5E5EA"
                StrokeThickness="1"
                BackgroundColor="White">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Show Archived"
                       FontSize="14"
                       TextColor="#3A3A3C"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding ShowDeleted}"
                        OnColor="#FF3B30" />
            </Grid>
        </Border>

        <!-- LOADING -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#1A1A2E"
                           HeightRequest="32" />

        <!-- VEHICLE LIST -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Vehicles}">

            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8"
                             Padding="24">
                    <Label Text="No vehicles"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#3A3A3C"
                           HorizontalOptions="Center" />
                    <Label Text="Tap + Add to get started"
                           FontSize="13"
                           TextColor="#8E8E93"
                           HorizontalOptions="Center" />
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Vehicle">
                    <Border Margin="0,5"
                            Padding="16"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#E5E5EA"
                            StrokeThickness="1"
                            BackgroundColor="{Binding IsDeleted, Converter={StaticResource DeletedColorConverter}}">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="8">

                            <!-- ROW 0 — Name + Type + Archived Badge -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <HorizontalStackLayout Grid.Column="0" Spacing="10">
                                    <Label Text="{Binding DisplayName}"
                                           FontSize="17"
                                           FontFamily="PoppinsSemiBold"
                                           TextColor="#1A1A2E"
                                           VerticalOptions="Center" />
                                    <Border Padding="8,3"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent"
                                            BackgroundColor="#F0F0F5">
                                        <Label Text="{Binding Type}"
                                               FontSize="11"
                                               TextColor="#636366" />
                                    </Border>
                                </HorizontalStackLayout>

                                <Border Grid.Column="1"
                                        Padding="8,3"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        BackgroundColor="#FFEBE6"
                                        IsVisible="{Binding IsDeleted}">
                                    <Label Text="ARCHIVED"
                                           FontSize="10"
                                           TextColor="#C0392B"
                                           FontFamily="PoppinsSemiBold" />
                                </Border>
                            </Grid>

                            <!-- ROW 1 — Plate / Color / Seats -->
                            <HorizontalStackLayout Grid.Row="1" Spacing="16">
                                <Label Text="{Binding PlateNumber}"
                                       FontSize="13"
                                       FontFamily="PoppinsMedium"
                                       TextColor="#3A3A3C" />
                                <Label Text="{Binding Color}"
                                       FontSize="13"
                                       TextColor="#636366" />
                                <Label Text="{Binding Seats, StringFormat='{0} seats'}"
                                       FontSize="13"
                                       TextColor="#636366" />
                            </HorizontalStackLayout>

                            <!-- ROW 2 — Description -->
                            <Label Grid.Row="2"
                                   Text="{Binding Description}"
                                   FontSize="12"
                                   TextColor="#8E8E93"
                                   LineBreakMode="TailTruncation" />

                            <!-- ROW 3 — Price + Status -->
                            <HorizontalStackLayout Grid.Row="3" Spacing="12">
                                <Label Text="{Binding PricePerDay, StringFormat='P{0:N0}/day'}"
                                       FontSize="18"
                                       FontFamily="PoppinsSemiBold"
                                       TextColor="#1A1A2E"
                                       VerticalOptions="Center" />
                                <Border Padding="10,4"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="Transparent"
                                        BackgroundColor="{Binding StatusBg}">
                                    <Label Text="{Binding Status}"
                                           FontSize="12"
                                           FontFamily="PoppinsSemiBold"
                                           TextColor="{Binding StatusColor}" />
                                </Border>
                            </HorizontalStackLayout>

                            <!-- ROW 4 — Action Buttons -->
                            <HorizontalStackLayout Grid.Row="4"
                                                   Spacing="8"
                                                   HorizontalOptions="End"
                                                   Margin="0,4,0,0">

                                <Button Text="Edit"
                                        FontSize="12"
                                        BackgroundColor="#1A1A2E"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="16,8"
                                        IsVisible="{Binding IsDeleted, Converter={StaticResource InverseBoolConverter}}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToUpdateCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Archive"
                                        FontSize="12"
                                        BackgroundColor="#F5A623"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="16,8"
                                        IsVisible="{Binding IsDeleted, Converter={StaticResource InverseBoolConverter}}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SoftDeleteCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Restore"
                                        FontSize="12"
                                        BackgroundColor="#34C759"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="16,8"
                                        IsVisible="{Binding IsDeleted}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RestoreCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Delete"
                                        FontSize="12"
                                        BackgroundColor="#FF3B30"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="16,8"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.HardDeleteCommand}"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
