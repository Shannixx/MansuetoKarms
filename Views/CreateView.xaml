<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MansuetoKarms.ViewModels"
             x:Class="MansuetoKarms.Views.CreateView"
             x:DataType="vm:CreateViewModel"
             BackgroundColor="#EAF2FB"
             Title="{Binding Title}">

    <ScrollView>
        <StackLayout Padding="24" Spacing="22">

            <!-- HEADER -->
            <StackLayout Spacing="4">
                <Label Text="New Vehicle"
                       FontSize="26"
                       FontFamily="PoppinsBold"
                       TextColor="#0A1931" />
                <Label Text="Fill in the details below"
                       FontSize="13"
                       TextColor="#5B7AA5" />
            </StackLayout>

            <!-- FORM CARD -->
            <Border Padding="20"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#B0CBE8"
                    StrokeThickness="1"
                    BackgroundColor="White">
                <StackLayout Spacing="18">

                    <!-- Brand -->
                    <StackLayout Spacing="6">
                        <Label Text="Brand"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Entry Placeholder="e.g. Toyota"
                                   Text="{Binding Brand}"
                                   TextColor="#0A1931"
                                   PlaceholderColor="#7BA0C7"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Model / Name -->
                    <StackLayout Spacing="6">
                        <Label Text="Model / Name"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Entry Placeholder="e.g. Fortuner, Vios"
                                   Text="{Binding Name}"
                                   TextColor="#0A1931"
                                   PlaceholderColor="#7BA0C7"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Vehicle Type -->
                    <StackLayout Spacing="6">
                        <Label Text="Vehicle Type"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Picker ItemsSource="{Binding VehicleTypes}"
                                    SelectedItem="{Binding Type}"
                                    Title="Select type"
                                    TextColor="#0A1931"
                                    TitleColor="#7BA0C7"
                                    FontSize="14"
                                    BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Plate Number -->
                    <StackLayout Spacing="6">
                        <Label Text="Plate Number"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Entry Placeholder="e.g. ABC 1234"
                                   Text="{Binding PlateNumber}"
                                   TextColor="#0A1931"
                                   PlaceholderColor="#7BA0C7"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Color -->
                    <StackLayout Spacing="6">
                        <Label Text="Color"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Entry Placeholder="e.g. White, Black"
                                   Text="{Binding Color}"
                                   TextColor="#0A1931"
                                   PlaceholderColor="#7BA0C7"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Price Per Day -->
                    <StackLayout Spacing="6">
                        <Label Text="Price Per Day (P)"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Entry Placeholder="0.00"
                                   Text="{Binding PricePerDay}"
                                   Keyboard="Numeric"
                                   TextColor="#0A1931"
                                   PlaceholderColor="#7BA0C7"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Number of Seats -->
                    <StackLayout Spacing="6">
                        <Label Text="Number of Seats"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Entry Placeholder="e.g. 5"
                                   Text="{Binding Seats}"
                                   Keyboard="Numeric"
                                   TextColor="#0A1931"
                                   PlaceholderColor="#7BA0C7"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Status -->
                    <StackLayout Spacing="6">
                        <Label Text="Status"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Picker ItemsSource="{Binding StatusOptions}"
                                    SelectedItem="{Binding Status}"
                                    Title="Select status"
                                    TextColor="#0A1931"
                                    TitleColor="#7BA0C7"
                                    FontSize="14"
                                    BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Description -->
                    <StackLayout Spacing="6">
                        <Label Text="Description"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#0A1931" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="#F0F7FF">
                            <Editor Placeholder="Additional notes..."
                                    Text="{Binding Description}"
                                    HeightRequest="100"
                                    TextColor="#0A1931"
                                    PlaceholderColor="#7BA0C7"
                                    FontSize="14"
                                    BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                </StackLayout>
            </Border>

            <!-- BUTTONS (Responsive) -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="#D6EAF8"
                        TextColor="#0A1931"
                        CornerRadius="12"
                        HeightRequest="50"
                        FontFamily="PoppinsMedium"
                        FontSize="15"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="Save Vehicle"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#1565C0"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="50"
                        FontFamily="PoppinsSemiBold"
                        FontSize="15"
                        HorizontalOptions="Fill" />
            </Grid>

            <!-- LOADING -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1565C0" />

        </StackLayout>
    </ScrollView>

</ContentPage>
