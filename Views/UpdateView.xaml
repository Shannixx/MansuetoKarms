<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MansuetoKarms.ViewModels"
             x:Class="MansuetoKarms.Views.UpdateView"
             x:DataType="vm:UpdateViewModel"
             BackgroundColor="#F5F5F7"
             Title="{Binding Title}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">

            <!-- HEADER -->
            <StackLayout Spacing="4">
                <Label Text="Edit Vehicle"
                       FontSize="26"
                       FontFamily="PoppinsBold"
                       TextColor="#1A1A2E" />
                <Label Text="Update the vehicle information below"
                       FontSize="13"
                       TextColor="#8E8E93" />
            </StackLayout>

            <!-- FORM CARD -->
            <Border Padding="20"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#E5E5EA"
                    StrokeThickness="1"
                    BackgroundColor="White">
                <StackLayout Spacing="18">

                    <!-- Brand -->
                    <StackLayout Spacing="6">
                        <Label Text="Brand"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry Placeholder="e.g. Toyota"
                                   Text="{Binding Brand}"
                                   TextColor="#1A1A2E"
                                   PlaceholderColor="#C7C7CC"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Model / Name -->
                    <StackLayout Spacing="6">
                        <Label Text="Model / Name"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry Placeholder="e.g. Fortuner, Vios"
                                   Text="{Binding Name}"
                                   TextColor="#1A1A2E"
                                   PlaceholderColor="#C7C7CC"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Vehicle Type -->
                    <StackLayout Spacing="6">
                        <Label Text="Vehicle Type"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Picker ItemsSource="{Binding VehicleTypes}"
                                    SelectedItem="{Binding Type}"
                                    Title="Select type"
                                    TextColor="#1A1A2E"
                                    TitleColor="#C7C7CC"
                                    FontSize="14"
                                    BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Plate Number -->
                    <StackLayout Spacing="6">
                        <Label Text="Plate Number"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry Placeholder="e.g. ABC 1234"
                                   Text="{Binding PlateNumber}"
                                   TextColor="#1A1A2E"
                                   PlaceholderColor="#C7C7CC"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Color -->
                    <StackLayout Spacing="6">
                        <Label Text="Color"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry Placeholder="e.g. White, Black"
                                   Text="{Binding Color}"
                                   TextColor="#1A1A2E"
                                   PlaceholderColor="#C7C7CC"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Price Per Day -->
                    <StackLayout Spacing="6">
                        <Label Text="Price Per Day (P)"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry Placeholder="0.00"
                                   Text="{Binding PricePerDay}"
                                   Keyboard="Numeric"
                                   TextColor="#1A1A2E"
                                   PlaceholderColor="#C7C7CC"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Number of Seats -->
                    <StackLayout Spacing="6">
                        <Label Text="Number of Seats"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Entry Placeholder="e.g. 5"
                                   Text="{Binding Seats}"
                                   Keyboard="Numeric"
                                   TextColor="#1A1A2E"
                                   PlaceholderColor="#C7C7CC"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Status -->
                    <StackLayout Spacing="6">
                        <Label Text="Status"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Picker ItemsSource="{Binding StatusOptions}"
                                    SelectedItem="{Binding Status}"
                                    Title="Select status"
                                    TextColor="#1A1A2E"
                                    TitleColor="#C7C7CC"
                                    FontSize="14"
                                    BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                    <!-- Description -->
                    <StackLayout Spacing="6">
                        <Label Text="Description"
                               FontFamily="PoppinsMedium"
                               FontSize="13"
                               TextColor="#3A3A3C" />
                        <Border Padding="12,10"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E5EA"
                                StrokeThickness="1"
                                BackgroundColor="#FAFAFA">
                            <Editor Placeholder="Additional notes..."
                                    Text="{Binding Description}"
                                    HeightRequest="80"
                                    TextColor="#1A1A2E"
                                    PlaceholderColor="#C7C7CC"
                                    FontSize="14"
                                    BackgroundColor="Transparent" />
                        </Border>
                    </StackLayout>

                </StackLayout>
            </Border>

            <!-- BUTTONS -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="#E5E5EA"
                        TextColor="#3A3A3C"
                        CornerRadius="12"
                        Padding="0,14"
                        FontFamily="PoppinsMedium"
                        FontSize="14" />
                <Button Grid.Column="1"
                        Text="Update Vehicle"
                        Command="{Binding UpdateCommand}"
                        BackgroundColor="#1A1A2E"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="0,14"
                        FontFamily="PoppinsMedium"
                        FontSize="14" />
            </Grid>

            <!-- LOADING -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1A1A2E" />

        </StackLayout>
    </ScrollView>

</ContentPage>
