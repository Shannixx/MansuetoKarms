<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MansuetoKarms.ViewModels"
             xmlns:m="clr-namespace:MansuetoKarms.Models"
             x:Class="MansuetoKarms.Views.DeleteView"
             x:DataType="vm:DeleteViewModel"
             BackgroundColor="#EAF2FB"
             Title="{Binding Title}">

    <ScrollView>
        <StackLayout Padding="24" Spacing="22">

            <!-- HEADER -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                <Button Grid.Column="0"
                        Text="Back"
                        Command="{Binding GoBackCommand}"
                        BackgroundColor="#D6EAF8"
                        TextColor="#0A1931"
                        CornerRadius="10"
                        WidthRequest="60"
                        HeightRequest="44"
                        FontSize="14"
                        Padding="0"
                        VerticalOptions="Center" />
                <StackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Label Text="Deleted Vehicles"
                           FontSize="26"
                           FontFamily="PoppinsBold"
                           TextColor="#0A1931" />
                    <Label Text="Restore deleted vehicles to your fleet"
                           FontSize="12"
                           TextColor="#5B7AA5" />
                </StackLayout>
            </Grid>

            <!-- STATS CARD -->
            <Border Padding="18,16"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#B0CBE8"
                    StrokeThickness="1"
                    BackgroundColor="#1565C0">
                <StackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="{Binding DeletedCount}"
                           FontSize="32"
                           FontFamily="PoppinsBold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Deleted"
                           FontSize="13"
                           FontFamily="PoppinsMedium"
                           TextColor="#D6EAF8"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Border>

            <!-- LOADING -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1565C0"
                               HeightRequest="32" />

            <!-- DELETED VEHICLES LIST -->
            <StackLayout Spacing="12">
                <Label Text="Deleted Vehicles"
                       FontSize="18"
                       FontFamily="PoppinsSemiBold"
                       TextColor="#0A1931" />
                <Label Text="These vehicles were deleted. Restore to re-add them to your fleet."
                       FontSize="12"
                       TextColor="#5B7AA5" />

                <CollectionView ItemsSource="{Binding DeletedVehicles}"
                                HeightRequest="500">

                    <CollectionView.EmptyView>
                        <Border Padding="24,28"
                                StrokeShape="RoundRectangle 14"
                                Stroke="#B0CBE8"
                                StrokeThickness="1"
                                BackgroundColor="White">
                            <StackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="No deleted vehicles"
                                       FontSize="15"
                                       FontFamily="PoppinsMedium"
                                       TextColor="#0A1931"
                                       HorizontalOptions="Center" />
                                <Label Text="Deleted vehicles will appear here"
                                       FontSize="12"
                                       TextColor="#5B7AA5"
                                       HorizontalOptions="Center" />
                            </StackLayout>
                        </Border>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:DeletedVehicleItem">
                            <Border Margin="0,5"
                                    Padding="16"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#B0CBE8"
                                    StrokeThickness="1"
                                    BackgroundColor="White">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">

                                    <!-- Name + Type -->
                                    <HorizontalStackLayout Grid.Row="0" Spacing="10">
                                        <Label Text="{Binding DisplayName}"
                                               FontSize="16"
                                               FontFamily="PoppinsSemiBold"
                                               TextColor="#0A1931"
                                               VerticalOptions="Center" />
                                        <Border Padding="8,3"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                BackgroundColor="#D6EAF8">
                                            <Label Text="{Binding Type}"
                                                   FontSize="11"
                                                   TextColor="#1565C0" />
                                        </Border>
                                    </HorizontalStackLayout>

                                    <!-- Details -->
                                    <HorizontalStackLayout Grid.Row="1" Spacing="14">
                                        <Label Text="{Binding PlateNumber}"
                                               FontSize="12"
                                               FontFamily="PoppinsMedium"
                                               TextColor="#0A1931" />
                                        <Label Text="{Binding Color}"
                                               FontSize="12"
                                               TextColor="#5B7AA5" />
                                        <Label Text="{Binding PricePerDay, StringFormat='P{0:N0}/day'}"
                                               FontSize="12"
                                               FontFamily="PoppinsSemiBold"
                                               TextColor="#1565C0" />
                                    </HorizontalStackLayout>

                                    <!-- Deleted timestamp -->
                                    <Label Grid.Row="2"
                                           Text="{Binding DeletedAtFormatted, StringFormat='Deleted: {0}'}"
                                           FontSize="11"
                                           TextColor="#7BA0C7" />

                                    <!-- Restore Button -->
                                    <Button Grid.Row="3"
                                            Text="Restore"
                                            FontSize="13"
                                            BackgroundColor="#0A1931"
                                            TextColor="White"
                                            CornerRadius="10"
                                            Padding="20,10"
                                            HeightRequest="40"
                                            FontFamily="PoppinsSemiBold"
                                            HorizontalOptions="End"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RestoreDeletedCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>

        </StackLayout>
    </ScrollView>

</ContentPage>